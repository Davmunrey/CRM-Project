# Copy to `.env.e2e`, fill with real values (never commit `.env.e2e`).
# Run: npm run test:e2e:integrations:local
#
# E2E_SUPABASE_URL — same host as VITE_SUPABASE_URL (no trailing slash).
E2E_SUPABASE_URL=https://your-project-ref.supabase.co
#
# E2E_SUPABASE_ANON_KEY — Project Settings → API → anon public key.
E2E_SUPABASE_ANON_KEY=your-anon-key
#
# User must exist, email+password auth enabled, and be admin|owner|manager in the org below.
E2E_USER_EMAIL=qa@yourcompany.com
E2E_USER_PASSWORD=your-secure-test-password
#
# organizations.id for that user (UUID from Supabase Table Editor or app network tab).
# Another company/org in the same project: use a different UUID + a user who is admin|owner|manager there.
E2E_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
