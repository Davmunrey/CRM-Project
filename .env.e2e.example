# Copy to `.env.e2e`, fill with real values (never commit `.env.e2e`).
# Run: npm run test:e2e:integrations:local

# Base URL of the velo-api instance to smoke-test (no trailing slash).
# Staging example: https://api.staging.velo.internal
E2E_API_URL=http://localhost:3001

# A user that exists in the target velo-api with admin|owner|manager role.
E2E_USER_EMAIL=qa@yourcompany.com
E2E_USER_PASSWORD=your-secure-test-password
