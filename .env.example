# Deploy channel — drives build checks (see src/lib/envChannel.ts).
# production | staging | (omit in local dev → development)
# VITE_APP_CHANNEL=production

# Supabase — required for production builds; needed for auth and data in development.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: strict multi-tenant root only. If omitted, the first hostname label is used as workspace slug when the host
# looks like a real company domain (e.g. acme.example.com → acme), and PaaS preview hosts are skipped.
# Example with explicit root: VITE_WORKSPACE_ROOT_DOMAIN=crm.example.com → only *.crm.example.com
# VITE_WORKSPACE_ROOT_DOMAIN=

# CI / static host: set keys + channel per environment in the hosting dashboard. Never commit production secrets.
# See docs/deployment-spa-and-env.md (DEPLOY-02).

# Optional: backend endpoint for Google SSO / tenant policy discovery (not used when login is email+password only).
# In production, set VITE_AUTH_GOOGLE_DISCOVERY_REQUIRED=true if you enforce this flow server-side.
# Example response:
# {
#   "allowGoogleOAuth": true,
#   "googleHostedDomain": "company.com",
#   "preferredProvider": "google"
# }
# VITE_AUTH_GOOGLE_DISCOVERY_ENDPOINT=https://api.your-backend.com/auth/sso/discovery
# VITE_AUTH_GOOGLE_DISCOVERY_REQUIRED=false

# Optional scheduler runner env vars (for npm run maintenance:lead:org / :all)
# SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1
# SUPABASE_ANON_KEY=your-anon-key-here
# LEAD_MAINTENANCE_SECRET=shared-secret-configured-in-edge-function-env
# LEAD_MAINTENANCE_ORG_ID=00000000-0000-0000-0000-000000000000
# LEAD_MAINTENANCE_SLA_HOURS=8
# LEAD_MAINTENANCE_SLA_COOLDOWN_HOURS=6
# LEAD_MAINTENANCE_SLA_NOTIFY_MANAGERS=true

# Outbound email provider selection
# Default is gmail when unset/invalid
# VITE_EMAIL_PROVIDER=gmail

# Resend provider settings (required only when VITE_EMAIL_PROVIDER=resend)
# Frontend only needs the Edge Function name (optional if default is used).
# VITE_EMAIL_PROVIDER=resend
# VITE_RESEND_SEND_FUNCTION=resend-send-email

# Outbound webhooks — GitHub Actions scheduler (optional; see .github/workflows/webhook-worker.yml)
# Full URL to the deployed function, e.g. https://<project-ref>.supabase.co/functions/v1/webhook-worker
# WEBHOOK_WORKER_INVOKE_URL=
# Same value as Supabase Edge secret WEBHOOK_WORKER_SECRET
# WEBHOOK_WORKER_SECRET=

# --- Optional: Playwright API smoke (API keys + lead capture) ---
# Copy .env.e2e.example → .env.e2e, then: npm run test:e2e:integrations:local
# See docs/deployment-spa-and-env.md#e2e-integrations-smoke

# Configure these ONLY in Supabase Edge Function env vars (server-side):
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM=Velo <noreply@yourdomain.com>
# Optional: restrict Reply-To to a single domain (see supabase/functions/resend-send-email)
# RESEND_ALLOWED_REPLY_DOMAIN=yourdomain.com
# Optional rate limits (defaults: 60/user/hour, 500/org/hour when org resolved via service role)
# RESEND_RATE_MAX_PER_USER_PER_HOUR=60
# RESEND_RATE_MAX_PER_ORG_PER_HOUR=500
