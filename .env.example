# Propel — environment variables
# Copy to .env.local and fill from your Supabase project dashboard.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser; everything else is
# server-only (Edge Functions, server actions, CI).

# ── Supabase (required) ───────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only — never expose to the browser (Edge Functions, server actions)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Sentry browser DSN
# NEXT_PUBLIC_SENTRY_DSN=

# ── AI providers (Edge Functions, optional) ───────────────────────────────────
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Email (optional) ──────────────────────────────────────────────────────────
# RESEND_API_KEY=

# ── Google OAuth — Gmail / Calendar (optional) ────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Stripe billing (optional) ─────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── n8n integration ───────────────────────────────────────────────────────────
# HMAC secret used to sign every outbound webhook payload sent to n8n.
# Generate with: openssl rand -hex 32
# Set as an Edge Function secret: supabase secrets set N8N_SIGNING_SECRET=...
N8N_SIGNING_SECRET=
# AES key (32-byte hex) used to encrypt stored n8n API keys at rest.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=
