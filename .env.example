# Supabase (required in production builds — see README and docs/deployment-spa-and-env.md)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# CI / static host: set the same keys per environment in the hosting dashboard (Production vs Preview).
# Never commit production secrets. See docs/deployment-spa-and-env.md (DEPLOY-02).

# Local-only: seed demo users + mock auth when Supabase env is missing (never used in production)
# VITE_ALLOW_DEMO_MODE=true

# Optional auth provider toggles for login UI
VITE_AUTH_GOOGLE_ENABLED=true
VITE_AUTH_AZURE_ENABLED=true
VITE_AUTH_APPLE_ENABLED=true
VITE_AUTH_SAML_ENABLED=true

# Optional backend endpoint to resolve SAML domain by email.
# If not set, the login infers domain from "user@domain.com".
# Expected payload contract:
# POST <endpoint> { "email": "user@company.com" } => { "domain": "company.com" }
# VITE_AUTH_SAML_DISCOVERY_ENDPOINT=https://api.your-backend.com/auth/sso/discovery

# Optional backend endpoint to resolve Google tenant policy for enterprise SSO.
# If not set, optional mode allows Google OAuth fallback.
# In production, set VITE_AUTH_GOOGLE_DISCOVERY_REQUIRED=true.
# Example response:
# {
#   "allowGoogleOAuth": true,
#   "googleHostedDomain": "company.com",
#   "preferredProvider": "google"
# }
# VITE_AUTH_GOOGLE_DISCOVERY_ENDPOINT=https://api.your-backend.com/auth/sso/discovery
# VITE_AUTH_GOOGLE_DISCOVERY_REQUIRED=false

# Optional scheduler runner env vars (for npm run maintenance:lead:org / :all)
# SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1
# SUPABASE_ANON_KEY=your-anon-key-here
# LEAD_MAINTENANCE_SECRET=shared-secret-configured-in-edge-function-env
# LEAD_MAINTENANCE_ORG_ID=00000000-0000-0000-0000-000000000000
# LEAD_MAINTENANCE_SLA_HOURS=8
# LEAD_MAINTENANCE_SLA_COOLDOWN_HOURS=6
# LEAD_MAINTENANCE_SLA_NOTIFY_MANAGERS=true

# Outbound email provider selection
# Default is gmail when unset/invalid
# VITE_EMAIL_PROVIDER=gmail

# Resend provider settings (required only when VITE_EMAIL_PROVIDER=resend)
# Frontend only needs the Edge Function name (optional if default is used).
# VITE_EMAIL_PROVIDER=resend
# VITE_RESEND_SEND_FUNCTION=resend-send-email

# Configure these ONLY in Supabase Edge Function env vars (server-side):
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM=CRM Pro <noreply@yourdomain.com>
# Optional: restrict Reply-To to a single domain (see supabase/functions/resend-send-email)
# RESEND_ALLOWED_REPLY_DOMAIN=yourdomain.com
# Optional rate limits (defaults: 60/user/hour, 500/org/hour when org resolved via service role)
# RESEND_RATE_MAX_PER_USER_PER_HOUR=60
# RESEND_RATE_MAX_PER_ORG_PER_HOUR=500
