{
  "name": "crm-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "maintenance:lead:org": "node scripts/run-lead-maintenance.mjs",
    "maintenance:lead:all": "node scripts/run-lead-maintenance.mjs --all",
    "maintenance:lead:health": "node scripts/check-lead-maintenance-health.mjs",
    "maintenance:lead:sla": "node scripts/check-lead-maintenance-sla.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "docs:md-inventory": "node scripts/md-chronology.mjs inventory",
    "docs:md-footers": "node scripts/md-chronology.mjs apply-footers",
    "docs:md-sort-state": "node scripts/md-chronology.mjs sort-state-key-decisions",
    "docs:verify-consolidation": "node scripts/verify-docs-consolidation.mjs",
    "docs:fix-phase-headers": "node scripts/fix-phase-note-headers.mjs",
    "lint": "eslint src tests e2e vite.config.ts playwright.config.ts --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint src tests e2e vite.config.ts playwright.config.ts --cache --cache-location node_modules/.cache/eslint/ --fix",
    "lint:ci": "eslint src --cache --cache-location node_modules/.cache/eslint/ --max-warnings 250",
    "ui:lint": "node scripts/ui-lint.mjs",
    "audit:unused": "npx -y knip --no-progress"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.100.1",
    "@types/uuid": "^10.0.0",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
