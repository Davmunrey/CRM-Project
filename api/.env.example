NODE_ENV=development
PORT=3001

# Database — PostgreSQL connection string
# Docker: postgresql://n0crm:n0crm_dev_pass@localhost:5432/n0crm
DATABASE_URL=postgresql://n0crm:n0crm_dev_pass@localhost:5432/n0crm

# Docker Compose postgres password (matches DATABASE_URL)
POSTGRES_PASSWORD=n0crm_dev_pass

# Auth — min 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=replace_with_random_64_char_hex_string
JWT_EXPIRES_IN=7d

# Self-registration policy. true (default) = open signup; false/0 = invite-only.
# The first user can always register (bootstrap). Optional domain allow-list.
ALLOW_OPEN_REGISTRATION=true
REGISTRATION_ALLOWED_DOMAINS=

# CORS — origin(s) allowed to call the API
CORS_ORIGIN=http://localhost:5174

# Redis — BullMQ job queues
REDIS_URL=redis://localhost:6379

# Frontend URL — used in transactional email links (reset / invite)
APP_URL=http://localhost:5174

# Email sender address
EMAIL_FROM=noreply@n0crm.com

# Outbound email — Resend (optional; leave blank to skip)
RESEND_API_KEY=

# Outbound email — SMTP fallback (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Google OAuth — Gmail integration (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5174/auth/gmail/callback

# ─── AI / Agentic features (multi-provider) ─────────────────────────────────
# Gemini is the free default. The AI assistant + agent activate as soon as ANY
# one provider key below is set; with none set the feature degrades gracefully
# (GET /ai/status reports enabled:false and the UI hides AI actions).
#
# Google Gemini (FREE) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# OpenAI (optional) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic (optional)
ANTHROPIC_API_KEY=
# Which provider to prefer when several keys are set / no per-org override.
AI_DEFAULT_PROVIDER=gemini
# Optional model overrides (defaults: gemini-2.0-flash / gpt-4o-mini / claude-sonnet-4-6)
AI_GEMINI_MODEL=
AI_OPENAI_MODEL=
AI_ANTHROPIC_MODEL=
# Max tool-call rounds per agent request (safety guardrail, 1-20).
AI_AGENT_MAX_STEPS=8
# Monthly output-token spend cap per org (0 = unlimited). Orgs can set a lower
# cap in settings.ai.monthlyTokenCap. Guards a shared provider key from abuse.
AI_MONTHLY_TOKEN_CAP=0
# Retention for AI conversations/messages/usage in days (0 = keep forever).
AI_MESSAGE_RETENTION_DAYS=0

# Trusted reverse-proxy hop count for client-IP resolution (rate limiting).
# Must match your topology: nginx only = 1; platform edge + nginx = 2; 0 = direct.
# Too high lets clients spoof X-Forwarded-For; too low collapses clients onto the proxy IP.
TRUST_PROXY=1

# Token encryption — openssl rand -hex 32 (required only for Gmail OAuth token storage)
TOKEN_ENCRYPTION_KEY=

# Seed defaults (used by npm run db:seed)
SEED_ADMIN_EMAIL=admin@n0crm.local
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_NAME=Admin
SEED_ORG_NAME=n0CRM Demo
SEED_ORG_SLUG=n0crm-demo
