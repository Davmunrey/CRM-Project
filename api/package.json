{
  "name": "n0crm-api",
  "version": "0.1.0",
  "description": "n0CRM — Fastify API server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node --import tsx/esm scripts/migrate.ts",
    "db:seed": "node --import tsx/esm scripts/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.2.2",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.51.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.2",
    "ioredis": "^5.6.0",
    "nodemailer": "^8.0.7",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "socket.io": "^4.8.1",
    "stripe": "22.1.1",
    "tsx": "^4.19.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
