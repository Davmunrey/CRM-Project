{
  "name": "Velo CRM",
  "slug": "velo-crm",
  "description": "Outbound-native CRM frontend for high-velocity sales teams. Nginx SPA that proxies /api/* to the Velo API service.",
  "badge": "Internal",
  "icon": {
    "letter": "V",
    "bg": "bg-blue-500/20",
    "color": "text-blue-400"
  },
  "open_btn_class": "bg-blue-500/20 hover:bg-blue-500/30 text-blue-400",
  "access_level": "public",
  "entrypoint": "web",
  "memory_mb": 128,
  "cpu": 0.25,
  "services": {
    "web": {
      "image": "gitea.apps.privateprompt.tech/clovrlabs/velo-crm:latest",
      "port": 80,
      "memory_mb": 128,
      "cpu": 0.25,
      "env": {
        "VELO_API_URL": {
          "secret": false,
          "generate": false,
          "label": "Velo API internal URL (e.g. http://velo-api:3001)",
          "default": "http://velo-api:3001"
        }
      },
      "healthcheck": {
        "test": ["CMD", "wget", "-qO-", "http://localhost:80/"],
        "interval": "30s",
        "timeout": "5s",
        "retries": 3,
        "start_period": "15s"
      }
    }
  },
  "post_install": {
    "description": "Static frontend served by nginx. Set VELO_API_URL to the internal URL of the Velo API service (default: http://velo-api:3001). Deploy the velo-api app first.",
    "first_run_url": "/"
  },
  "links": {
    "repository": "https://gitea.apps.privateprompt.tech/clovrlabs/velo-crm"
  }
}
