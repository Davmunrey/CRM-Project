{
  "name": "n0CRM",
  "slug": "n0crm",
  "description": "The connected, AI-native CRM for outbound sales teams — contacts, deals, pipelines, email sequences, Gmail & Calendar sync, automations, lead scoring, reports, and a multi-provider AI assistant. Fully managed and enterprise-secure (MFA, SSO/SCIM, RBAC, encryption, GDPR). API (Fastify + PostgreSQL + Redis) + frontend (nginx SPA) in a single deployment.",
  "badge": "Internal",
  "icon": {
    "letter": "n",
    "bg": "bg-indigo-500/20",
    "color": "text-indigo-400"
  },
  "open_btn_class": "bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-400",
  "access_level": "public",
  "entrypoint": "web",
  "memory_mb": 1408,
  "cpu": 3.25,
  "services": {
    "postgres": {
      "image": "postgres:16-alpine",
      "memory_mb": 512,
      "cpu": 0.75,
      "volume": "n0crm-postgres-data",
      "env": {
        "POSTGRES_DB":       { "secret": false, "generate": false, "label": "Database name",     "default": "n0crm" },
        "POSTGRES_USER":     { "secret": false, "generate": false, "label": "Database user",     "default": "n0crm" },
        "POSTGRES_PASSWORD": { "secret": true,  "generate": true,  "label": "Database password" }
      },
      "healthcheck": {
        "test": ["CMD-SHELL", "pg_isready -U n0crm"],
        "interval": "5s",
        "timeout": "5s",
        "retries": 10,
        "start_period": "10s"
      }
    },
    "redis": {
      "image": "redis:7-alpine",
      "memory_mb": 128,
      "cpu": 0.25,
      "comment": "AOF persistence so the JWT jti denylist, account-lockout counters and sessions-valid-after survive a Redis restart (without it, revoked tokens become replayable until expiry).",
      "command": ["redis-server", "--appendonly", "yes", "--appendfsync", "everysec"],
      "volumes": [
        { "name": "n0crm-redis-data", "mount": "/data" }
      ],
      "healthcheck": {
        "test": ["CMD", "redis-cli", "ping"],
        "interval": "5s",
        "timeout": "3s",
        "retries": 5,
        "start_period": "5s"
      }
    },
    "api": {
      "image": "gitea-clovrlabs.apps.privateprompt.tech/clovrlabs/n0crm-api:latest",
      "port": 3001,
      "memory_mb": 512,
      "cpu": 1.25,
      "volumes": [
        { "name": "n0crm-backups", "mount": "/backups" }
      ],
      "env": {
        "POSTGRES_PASSWORD":      { "secret": true,  "generate": false, "label": "DB Password (shared with postgres)" },
        "JWT_SECRET":             { "secret": true,  "generate": true,  "label": "JWT Secret" },
        "TOKEN_ENCRYPTION_KEY":   { "secret": true,  "generate": true,  "label": "Encryption Key" },
        "DEBUG_TOKEN":            { "secret": true,  "generate": true,  "label": "Debug Token" },
        "GEMINI_API_KEY":         { "secret": true,  "generate": false, "label": "Google Gemini API Key (free — enables AI assistant)", "default": "" },
        "OPENAI_API_KEY":         { "secret": true,  "generate": false, "label": "OpenAI API Key (optional AI provider)", "default": "" },
        "ANTHROPIC_API_KEY":      { "secret": true,  "generate": false, "label": "Anthropic API Key (optional AI provider)", "default": "" },
        "AI_DEFAULT_PROVIDER":    { "secret": false, "generate": false, "label": "Default AI provider", "default": "gemini" },
        "TRUST_PROXY":            { "secret": false, "generate": false, "label": "Trusted proxy hops (platform edge + nginx = 2)", "default": "2" },
        "REDIS_URL":              { "secret": false, "generate": false, "label": "Redis URL (internal service)", "default": "redis://redis:6379" },
        "APP_URL":                { "secret": false, "generate": false, "label": "Public app URL — used in password-reset / invite / booking email links (set to your domain)", "default": "https://n0crm.apps.privateprompt.tech" },
        "CORS_ORIGIN":            { "secret": false, "generate": false, "label": "Allowed CORS origin(s), comma-separated — no '*' in prod (set to your domain)", "default": "https://n0crm.apps.privateprompt.tech" },
        "EMAIL_FROM":             { "secret": false, "generate": false, "label": "Email From address", "default": "noreply@n0crm.com" },
        "RESEND_API_KEY":         { "secret": true,  "generate": false, "label": "Resend API Key (outbound email)", "default": "" }
      },
      "healthcheck": {
        "test": ["CMD", "wget", "-qO-", "http://localhost:3001/health"],
        "interval": "15s",
        "timeout": "5s",
        "retries": 5,
        "start_period": "60s"
      }
    },
    "web": {
      "image": "gitea-clovrlabs.apps.privateprompt.tech/clovrlabs/n0crm-api:web",
      "port": 80,
      "memory_mb": 256,
      "cpu": 1.0,
      "comment": "Static nginx SPA + reverse proxy to the API. Needs ONLY N0CRM_API_URL — DB/JWT/encryption/email secrets removed (nginx never reads them; they only widened the secret blast radius).",
      "env": {
        "N0CRM_API_URL":     { "secret": false, "generate": false, "label": "Internal API URL", "default": "http://api:3001" }
      },
      "healthcheck": {
        "test": ["CMD", "wget", "-qO-", "http://localhost:80/"],
        "interval": "30s",
        "timeout": "5s",
        "retries": 3,
        "start_period": "60s"
      }
    }
  },
  "post_install": {
    "description": "On first run the API applies all database migrations automatically, then the server starts. Register your organisation at /register. Required secrets are auto-generated: POSTGRES_PASSWORD, JWT_SECRET, TOKEN_ENCRYPTION_KEY. Optional: RESEND_API_KEY, GOOGLE_CLIENT_ID/SECRET, ANTHROPIC_API_KEY.",
    "first_run_url": "/register"
  },
  "links": {
    "repository": "https://gitea-clovrlabs.apps.privateprompt.tech/clovrlabs/n0crm"
  }
}
