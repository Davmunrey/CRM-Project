{
  "name": "Velo CRM",
  "slug": "velo-crm",
  "description": "Outbound-native CRM for high-velocity sales teams — contacts, deals, pipelines, email sequences, Gmail sync, automations, lead scoring, and reports. Nginx SPA frontend proxying /api/* to the Velo API service (velo-api). Deploy alongside velo-api.",
  "badge": "Internal",
  "icon": {
    "letter": "V",
    "bg": "bg-blue-500/20",
    "color": "text-blue-400"
  },
  "open_btn_class": "bg-blue-500/20 hover:bg-blue-500/30 text-blue-400",
  "access_level": "public",
  "entrypoint": "web",
  "memory_mb": 896,
  "cpu": 1.5,
  "services": {
    "postgres": {
      "image": "postgres:16-alpine",
      "memory_mb": 256,
      "cpu": 0.5,
      "env": {
        "POSTGRES_DB": { "secret": false, "generate": false, "label": "Database name", "default": "velo" },
        "POSTGRES_USER": { "secret": false, "generate": false, "label": "Database user", "default": "velo" },
        "POSTGRES_PASSWORD": { "secret": true, "generate": false, "label": "Database password", "default": "velo_db_2026_secure" }
      },
      "healthcheck": {
        "test": ["CMD-SHELL", "pg_isready -U velo"],
        "interval": "5s",
        "timeout": "5s",
        "retries": 10,
        "start_period": "10s"
      }
    },
    "redis": {
      "image": "redis:7-alpine",
      "memory_mb": 64,
      "cpu": 0.25,
      "healthcheck": {
        "test": ["CMD", "redis-cli", "ping"],
        "interval": "5s",
        "timeout": "3s",
        "retries": 5,
        "start_period": "5s"
      }
    },
    "web": {
      "image": "gitea.apps.privateprompt.tech/clovrlabs/velo-crm:latest",
      "port": 80,
      "memory_mb": 576,
      "cpu": 1.0,
      "env": {
        "POSTGRES_PASSWORD": { "secret": true, "generate": false, "label": "PostgreSQL password (shared with postgres service)", "default": "velo_db_2026_secure" },
        "JWT_SECRET": { "secret": true, "generate": true, "label": "JWT signing secret (32+ random bytes)" },
        "TOKEN_ENCRYPTION_KEY": { "secret": true, "generate": true, "label": "32-byte hex key for encrypting OAuth tokens (openssl rand -hex 32)" },
        "RESEND_API_KEY": { "secret": true, "generate": false, "label": "Resend API key for transactional email (optional)" },
        "EMAIL_FROM": { "secret": false, "generate": false, "label": "From address for transactional emails", "default": "noreply@velo.app" },
        "ANTHROPIC_API_KEY": { "secret": true, "generate": false, "label": "Anthropic API key for AI features — AI assistant, email drafting (optional)" },
        "VELO_API_URL": { "secret": true,  "generate": false, "label": "Public URL of the velo-api service (used by nginx to proxy /api/* — no trailing slash)", "default": "https://velo-api.apps.privateprompt.tech" }
      },
      "healthcheck": {
        "test": ["CMD", "wget", "-qO-", "http://localhost:80/"],
        "interval": "30s",
        "timeout": "5s",
        "retries": 3,
        "start_period": "60s"
      }
    }
  },
  "post_install": {
    "description": "On first run the API runs all database migrations automatically, then the server starts. Register your organisation at /register. Required secrets: POSTGRES_PASSWORD (default velo_db_2026_secure), JWT_SECRET (auto-generated). Optional: RESEND_API_KEY, ANTHROPIC_API_KEY.",
    "first_run_url": "/register"
  },
  "links": {
    "repository": "https://gitea.apps.privateprompt.tech/clovrlabs/velo-crm",
    "api": "https://gitea.apps.privateprompt.tech/clovrlabs/velo-api"
  }
}
