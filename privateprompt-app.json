{
  "name": "n0CRM",
  "slug": "n0crm",
  "description": "Outbound-native CRM — contacts, deals, pipelines, email sequences, Gmail sync, automations, lead scoring, and reports. Your infrastructure, your data, zero lock-in. Includes API (Fastify + PostgreSQL + Redis) and frontend (nginx SPA) in a single deployment.",
  "badge": "Internal",
  "icon": {
    "letter": "n",
    "bg": "bg-indigo-500/20",
    "color": "text-indigo-400"
  },
  "open_btn_class": "bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-400",
  "access_level": "public",
  "entrypoint": "web",
  "memory_mb": 1408,
  "cpu": 3.25,
  "services": {
    "postgres": {
      "image": "postgres:16-alpine",
      "memory_mb": 256,
      "cpu": 0.5,
      "volume": "n0crm-postgres-data",
      "env": {
        "POSTGRES_DB":       { "secret": false, "generate": false, "label": "Database name",     "default": "n0crm" },
        "POSTGRES_USER":     { "secret": false, "generate": false, "label": "Database user",     "default": "n0crm" },
        "POSTGRES_PASSWORD": { "secret": true,  "generate": true,  "label": "Database password" }
      },
      "healthcheck": {
        "test": ["CMD-SHELL", "pg_isready -U n0crm"],
        "interval": "5s",
        "timeout": "5s",
        "retries": 10,
        "start_period": "10s"
      }
    },
    "redis": {
      "image": "redis:7-alpine",
      "memory_mb": 64,
      "cpu": 0.25,
      "healthcheck": {
        "test": ["CMD", "redis-cli", "ping"],
        "interval": "5s",
        "timeout": "3s",
        "retries": 5,
        "start_period": "5s"
      }
    },
    "api": {
      "image": "gitea.apps.privateprompt.tech/clovrlabs/n0crm-api:latest",
      "port": 3001,
      "memory_mb": 256,
      "cpu": 0.75,
      "volumes": [
        { "name": "n0crm-backups", "mount": "/backups" }
      ],
      "env": {
        "POSTGRES_PASSWORD":      { "secret": true,  "generate": false, "label": "DB Password (shared with postgres)" },
        "JWT_SECRET":             { "secret": true,  "generate": true,  "label": "JWT Secret" },
        "TOKEN_ENCRYPTION_KEY":   { "secret": true,  "generate": true,  "label": "Encryption Key" },
        "CORS_ORIGIN":            { "secret": false, "generate": false, "label": "Frontend URL (CORS)", "default": "" },
        "EMAIL_FROM":             { "secret": false, "generate": false, "label": "Email From Address", "default": "noreply@n0crm.com" },
        "RESEND_API_KEY":         { "secret": true,  "generate": false, "label": "Resend API Key (optional)" },
        "SMTP_HOST":              { "secret": false, "generate": false, "label": "SMTP Host (optional)" },
        "SMTP_PORT":              { "secret": false, "generate": false, "label": "SMTP Port (optional)" },
        "SMTP_USER":              { "secret": true,  "generate": false, "label": "SMTP User (optional)" },
        "SMTP_PASS":              { "secret": true,  "generate": false, "label": "SMTP Password (optional)" },
        "GOOGLE_CLIENT_ID":       { "secret": true,  "generate": false, "label": "Google Client ID (optional)" },
        "GOOGLE_CLIENT_SECRET":   { "secret": true,  "generate": false, "label": "Google Client Secret (optional)" },
        "GOOGLE_REDIRECT_URI":    { "secret": false, "generate": false, "label": "Google Redirect URI (optional)" },
        "ANTHROPIC_API_KEY":      { "secret": true,  "generate": false, "label": "Anthropic API Key (optional)" },
        "DEBUG_TOKEN":            { "secret": true,  "generate": true,  "label": "Debug Token" },
        "BACKUP_INTERVAL_HOURS":  { "secret": false, "generate": false, "label": "Backup Interval (hours)", "default": "6" },
        "BACKUP_KEEP":            { "secret": false, "generate": false, "label": "Backup Retention Count", "default": "10" }
      },
      "healthcheck": {
        "test": ["CMD", "wget", "-qO-", "http://localhost:3001/health"],
        "interval": "15s",
        "timeout": "5s",
        "retries": 5,
        "start_period": "60s"
      }
    },
    "web": {
      "image": "gitea.apps.privateprompt.tech/clovrlabs/n0crm-api:web",
      "port": 80,
      "memory_mb": 832,
      "cpu": 1.75,
      "env": {
        "POSTGRES_PASSWORD": { "secret": true,  "generate": false, "label": "DB Password (shared with postgres)" },
        "JWT_SECRET":        { "secret": true,  "generate": true,  "label": "JWT Secret" },
        "TOKEN_ENCRYPTION_KEY": { "secret": true, "generate": true, "label": "Encryption Key" },
        "EMAIL_FROM":        { "secret": false, "generate": false, "label": "Email From", "default": "noreply@n0crm.com" },
        "RESEND_API_KEY":    { "secret": true,  "generate": false, "label": "Resend API Key", "default": "" },
        "ANTHROPIC_API_KEY": { "secret": true,  "generate": false, "label": "Anthropic API Key", "default": "" },
        "N0CRM_API_URL":     { "secret": false, "generate": false, "label": "Internal API URL", "default": "http://api:3001" }
      },
      "healthcheck": {
        "test": ["CMD", "wget", "-qO-", "http://localhost:80/"],
        "interval": "30s",
        "timeout": "5s",
        "retries": 3,
        "start_period": "60s"
      }
    }
  },
  "post_install": {
    "description": "On first run the API applies all database migrations automatically, then the server starts. Register your organisation at /register. Required secrets are auto-generated: POSTGRES_PASSWORD, JWT_SECRET, TOKEN_ENCRYPTION_KEY. Optional: RESEND_API_KEY, GOOGLE_CLIENT_ID/SECRET, ANTHROPIC_API_KEY.",
    "first_run_url": "/register"
  },
  "links": {
    "repository": "https://gitea.apps.privateprompt.tech/clovrlabs/n0crm"
  }
}
